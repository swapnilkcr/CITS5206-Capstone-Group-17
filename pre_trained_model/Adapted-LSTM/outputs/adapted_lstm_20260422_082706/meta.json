{
  "splits": {
    "train": "valve1_train",
    "val": "valve1_val",
    "test": "valve1_test",
    "valve2_test": "valve2_test"
  },
  "dataset_dir": "/workspace/CITS5206-Capstone-Group-17/Adapted-LSTM/dataset",
  "config": {
